<Window x:Class="PortGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PortGuard.App.Converters"
        xmlns:viewmodels="clr-namespace:PortGuard.App.ViewModels"
        Title="🔌 PortGuard"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolInverter x:Key="InvertBool"/>
        <converters:NullToBoolConverter x:Key="NullToBool"/>
        <converters:NullToAllConverter x:Key="NullToAll"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding KillCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter + Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Command="{Binding RefreshCommand}" ToolTip="Refresh (F5)" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>

                    <Button Click="ToggleAutoRefresh" ToolTip="Toggle auto-refresh" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding AutoRefresh, StringFormat=Auto:\ {0}}"/>
                        </StackPanel>
                    </Button>

                    <ComboBox ItemsSource="{Binding IntervalOptions}"
                              SelectedIndex="1"
                              ToolTip="Refresh interval (seconds)" Margin="0,0,12,0"
                              MinWidth="60">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat={}{0}s}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Style="{StaticResource DangerButton}" Command="{Binding KillCommand}"
                            ToolTip="Kill selected process (Del)" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Kill"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search by process name, port, or address (Ctrl+F to focus)"
                         Margin="0,0,10,0"/>

                <!-- Filter dropdowns -->
                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <TextBlock Text="Proto:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding ProtocolFilterOptions}"
                              SelectedItem="{Binding SelectedProtocol}"
                              Margin="0,0,10,0" MinWidth="75"
                              DisplayMemberPath="."/>

                    <TextBlock Text="State:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding StateFilterOptions}"
                              SelectedItem="{Binding SelectedState}"
                              MinWidth="110"
                              DisplayMemberPath="."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid + Detail Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredPorts}"
                      SelectedItem="{Binding SelectedPort}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70"/>
                    <DataGridTemplateColumn Header="Proto" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="4,2"
                                        Background="{Binding ProtocolColor}" Opacity="0.15">
                                    <TextBlock Text="{Binding Protocol}"
                                               Foreground="{Binding ProtocolColor}"
                                               FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="State" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding StateColor}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StateText}" Foreground="{Binding StateColor}"
                                               FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Local Address" Binding="{Binding LocalAddress}" Width="160"/>
                    <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="160"/>
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DETAILS" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource FgSecondary}" Margin="0,0,0,14"/>

                        <!-- Port info -->
                        <TextBlock Text="Port" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.Port, StringFormat='Port {0}'}"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>

                        <TextBlock Text="Protocol" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.Protocol}" FontSize="14"/>

                        <TextBlock Text="State" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.StateText}" FontSize="14"
                                   Foreground="{Binding SelectedPort.StateColor}"/>

                        <Separator Margin="0,14,0,10" Background="{StaticResource Border}"/>

                        <!-- Process info -->
                        <TextBlock Text="Process" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.ProcessName}" FontSize="14" FontWeight="SemiBold"/>

                        <TextBlock Text="PID" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.ProcessId}" FontSize="14"/>

                        <TextBlock Text="Path" FontSize="11" Foreground="{StaticResource FgSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SelectedPort.ProcessPath}" FontSize="12"
                                   TextWrapping="Wrap" Foreground="{StaticResource FgSecondary}"/>

                        <Separator Margin="0,14,0,10" Background="{StaticResource Border}"/>

                        <!-- Actions -->
                        <Button Style="{StaticResource DangerButton}" Command="{Binding KillCommand}"
                                IsEnabled="{Binding IsPortSelected}"
                                Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Kill Process"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenFileLocationCommand}"
                                IsEnabled="{Binding IsPortSelected}" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Open File Location"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CopyCommand}"
                                IsEnabled="{Binding IsPortSelected}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Copy Info"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Padding="10,4">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1" Margin="0,0,16,0">
                <TextBlock>
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalCount}" FontWeight="Bold"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem Grid.Column="2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding IsAdmin, Converter={StaticResource InvertBool}, StringFormat='Admin: {0}'}"/>
                    <Ellipse Width="8" Height="8" Margin="6,0,0,0"
                             Fill="{Binding IsAdmin, Converter={x:Static converters:AdminColorConverter.Instance}}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
